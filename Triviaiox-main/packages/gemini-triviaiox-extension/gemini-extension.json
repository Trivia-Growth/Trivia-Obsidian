{
  "$schema": "https://geminicli.com/schemas/extension.json",
  "name": "triviaiox",
  "displayName": "TriviaGrowth Triviaiox",
  "version": "1.0.0",
  "description": "Multi-agent orchestration system for CLI-first development. Brings TRIVIAIOX agents, hooks, and workflows to Gemini CLI.",
  "author": "TriviaGrowth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/triviagrowth/triviaiox-core"
  },
  "engines": {
    "gemini-cli": ">=0.26.0"
  },
  "capabilities": {
    "hooks": true,
    "skills": true,
    "commands": true,
    "mcp": false
  },
  "activation": {
    "onStartup": true,
    "conditions": [
      {
        "type": "fileExists",
        "path": ".triviaiox-core"
      }
    ]
  },
  "commands": [
    {
      "name": "triviaiox-status",
      "description": "Show TRIVIAIOX system status and provider info",
      "script": "commands/triviaiox-status.js"
    },
    {
      "name": "triviaiox-agents",
      "description": "List available TRIVIAIOX agents",
      "script": "commands/triviaiox-agents.js"
    },
    {
      "name": "triviaiox-validate",
      "description": "Validate TRIVIAIOX installation and skills",
      "script": "commands/triviaiox-validate.js"
    },
    {
      "name": "triviaiox-menu",
      "description": "Show TRIVIAIOX quick agent menu for Gemini",
      "script": "commands/triviaiox-menu.js"
    },
    {
      "name": "triviaiox-agent",
      "description": "Prepare activation prompt for a specific TRIVIAIOX agent (/triviaiox-agent <id>)",
      "script": "commands/triviaiox-agent.js"
    },
    {
      "name": "triviaiox-master",
      "description": "Quick launch triviaiox-master agent",
      "script": "commands/triviaiox-master.js"
    },
    {
      "name": "triviaiox-analyst",
      "description": "Quick launch analyst agent",
      "script": "commands/triviaiox-analyst.js"
    },
    {
      "name": "triviaiox-architect",
      "description": "Quick launch architect agent",
      "script": "commands/triviaiox-architect.js"
    },
    {
      "name": "triviaiox-data-engineer",
      "description": "Quick launch data-engineer agent",
      "script": "commands/triviaiox-data-engineer.js"
    },
    {
      "name": "triviaiox-dev",
      "description": "Quick launch dev agent",
      "script": "commands/triviaiox-dev.js"
    },
    {
      "name": "triviaiox-devops",
      "description": "Quick launch devops agent",
      "script": "commands/triviaiox-devops.js"
    },
    {
      "name": "triviaiox-pm",
      "description": "Quick launch pm agent",
      "script": "commands/triviaiox-pm.js"
    },
    {
      "name": "triviaiox-po",
      "description": "Quick launch po agent",
      "script": "commands/triviaiox-po.js"
    },
    {
      "name": "triviaiox-qa",
      "description": "Quick launch qa agent",
      "script": "commands/triviaiox-qa.js"
    },
    {
      "name": "triviaiox-sm",
      "description": "Quick launch sm agent",
      "script": "commands/triviaiox-sm.js"
    },
    {
      "name": "triviaiox-squad-creator",
      "description": "Quick launch squad-creator agent",
      "script": "commands/triviaiox-squad-creator.js"
    },
    {
      "name": "triviaiox-ux-design-expert",
      "description": "Quick launch ux-design-expert agent",
      "script": "commands/triviaiox-ux-design-expert.js"
    }
  ],
  "skills": [
    {
      "name": "dev",
      "path": "skills/dev.md",
      "description": "Developer agent - code implementation"
    },
    {
      "name": "architect",
      "path": "skills/architect.md",
      "description": "Architect agent - system design"
    },
    {
      "name": "qa",
      "path": "skills/qa.md",
      "description": "QA agent - testing and quality"
    }
  ],
  "hooks": {
    "configPath": "hooks/hooks.json"
  },
  "keywords": [
    "triviaiox",
    "agents",
    "orchestration",
    "development",
    "ai",
    "claude",
    "multi-agent"
  ]
}
