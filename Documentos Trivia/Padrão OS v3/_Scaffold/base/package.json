{
  "name": "trivia-os-app",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Projeto baseado no Padrão OS da Trivia (perfil single-repo).",
  "scripts": {
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "audit:esteira": "node scripts/audit-esteira.mjs",
    "eval:spec": "node scripts/eval-spec-fidelity.mjs",
    "audit:deps": "npm audit --omit=dev --audit-level=high",
    "arch:check": "depcruise src --config .dependency-cruiser.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.3.0",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "dependency-cruiser": "^16.3.0"
  }
}
